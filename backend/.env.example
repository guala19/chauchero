# ─────────────────────────────────────────────────────────────────────────────
# Chauchero — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
#
# Generate SECRET_KEY with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local dev (Docker):  postgresql://chauchero:dev_password@localhost:5432/chauchero_db
# Production:          postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://chauchero:dev_password@localhost:5432/chauchero_db

# ── Security ──────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32

# JWT algorithm — do not change
ALGORITHM=HS256

# JWT expiry in minutes (60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
# OAuth 2.0 Client ID (ends in .apps.googleusercontent.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=your-client-secret

# Must match exactly what's configured in Google Cloud Console
# Development:  http://localhost:8000/auth/google/callback
# Production:   https://api.yourdomain.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Application ───────────────────────────────────────────────────────────────
# URL of the Next.js frontend (used for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:3000

# URL of this backend (used for OAuth callback construction)
BACKEND_URL=http://localhost:8000

# Environment: development | staging | production
ENVIRONMENT=development

# ── Gmail Sync ────────────────────────────────────────────────────────────────
# Number of parallel workers for fetching Gmail messages (default: 20)
GMAIL_FETCH_WORKERS=20

# Max emails to fetch per Gmail API query (default: 500)
GMAIL_MAX_RESULTS=500

# Hard cap on emails processed per sync request (default: 2000)
SYNC_MAX_EMAILS=2000

# Minimum minutes between sync requests per user (rate limiting, default: 5)
SYNC_COOLDOWN_MINUTES=5

# ── Observability (optional) ──────────────────────────────────────────────────
# Sentry DSN for error tracking. Leave empty to disable.
# Get from: https://sentry.io → Your Project → Settings → Client Keys
SENTRY_DSN=
