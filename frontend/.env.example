# ─────────────────────────────────────────────────────────────────────────────
# Chauchero Frontend — Environment Variables
# Copy this file to .env.local for local development.
# For production, set these in your hosting provider's dashboard (e.g. Vercel).
# ─────────────────────────────────────────────────────────────────────────────

# ── API URL (Client-side) ─────────────────────────────────────────────────────
# Exposed to the browser. Used for client-side fetch calls.
# Development: http://localhost:8000
# Production:  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── API URL (Server-side) ─────────────────────────────────────────────────────
# Only available in Next.js SSR / Server Components (not sent to the browser).
# Useful when the frontend and backend are on the same internal network.
# Development: http://127.0.0.1:8000  (avoids macOS IPv6 delay on "localhost")
# Production:  same as NEXT_PUBLIC_API_URL, or internal URL if on same network
INTERNAL_API_URL=http://127.0.0.1:8000
